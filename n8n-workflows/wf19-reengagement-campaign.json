    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const appts = $('Get Completed Patients').all();\nif (appts.length === 0 || !appts[0].json.id) {\n  return [{ json: { skipped: true } }];\n}\nconst map = {};\nfor (const a of appts) {\n  const pid = a.json.patient_id;\n  if (!pid) continue;\n  if (!map[pid] || new Date(a.json.slot_time) > new Date(map[pid].slot_time)) {\n    map[pid] = a.json;\n  }\n}\nconst unique = Object.values(map);\nreturn unique.map(a => ({ json: { patient_id: a.patient_id, clinic_id: a.clinic_id, last_appt: a.slot_time, message_type: 'completed' } }));"
      },
      "id": "wf19-n05",
      "name": "Dedupe Completed",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [860, 200]
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const appts = $('Get NoShow Patients').all();\nif (appts.length === 0 || !appts[0].json.id) {\n  return [{ json: { skipped: true } }];\n}\nconst map = {};\nfor (const a of appts) {\n  const pid = a.json.patient_id;\n  if (!pid) continue;\n  if (!map[pid] || new Date(a.json.slot_time) > new Date(map[pid].slot_time)) {\n    map[pid] = a.json;\n  }\n}\nconst unique = Object.values(map);\nreturn unique.map(a => ({ json: { patient_id: a.patient_id, clinic_id: a.clinic_id, last_appt: a.slot_time, message_type: 'no_show' } }));"
      },
