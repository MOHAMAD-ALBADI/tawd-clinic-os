      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const patient = $json;\nconst ctx     = $('Expand Patients Completed').itemMatching($itemIndex).json;\nif (!patient.id || !patient.phone) {\n  return { json: { ...ctx, skip: true, reason: 'no phone' } };\n}\nreturn { json: {\n  ...ctx,\n  phone:        patient.phone,\n  patient_name: patient.name || patient.name_ar || '',\n  message_text: ctx.message,\n  skip:         false\n} };"
      },
