        "jsCode": "const all = $input.all().map(i => i.json);\nif (!all.length || all[0].skipped) {\n  return [{ json: { skipped: true } }];\n}\nconst clinic_id = all[0].clinic_id;\nreturn [{ json: { clinic_id, patients: all, patient_count: all.length, message_type: 'completed' } }];"
      },
