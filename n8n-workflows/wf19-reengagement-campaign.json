      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const campaign = $('Create Campaign Completed').first().json;\nconst allData  = $('Collect Completed').first().json;\nconst patients = allData.patients || [];\nreturn patients.map(p => ({ json: {\n  campaign_id:  campaign.id,\n  clinic_id:    p.clinic_id,\n  patient_id:   p.patient_id,\n  last_appt:    p.last_appt,\n  message_type: 'completed',\n  message:      'نشتاق لك! مضى وقت من آخر زيارتك. احجز موعدك الآن وفريقنا بانتظارك.'\n} }));"
