    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const d = $json;\nconst daysSince = Math.floor((Date.now() - new Date(d.last_appt)) / (1000*60*60*24));\nconst name = d.patient_name || 'عزيزي المريض';\nlet promptText;\nif (d.message_type === 'completed') {\n  promptText = 'أنت مساعد ودّي لعيادة طبية. اكتب رسالة واتساب قصيرة (3 جمل فقط) بالعربية الفصحى البسيطة لإعادة تواصل مع مريض. المريض: ' + name + '. آخر زيارة منذ ' + daysSince + ' يوماً (زيارة مكتملة). الرسالة تبدأ بتحية بالاسم، وتذكر مدة الغياب بشكل طبيعي، وتنتهي بدعوة واضحة للحجز. لا تتجاوز 40 كلمة ولا تستخدم إيموجي. اكتب الرسالة فقط:';\n} else {\n  promptText = 'أنت مساعد ودّي لعيادة طبية. اكتب رسالة واتساب قصيرة (3 جمل فقط) بالعربية الفصحى البسيطة لمريض فاته موعده. المريض: ' + name + '. الموعد الفائت منذ ' + daysSince + ' يوماً. الرسالة تبدأ بتحية بالاسم، وتُعبّر عن الأسف برفق دون لوم، وتعرض إعادة الحجز. لا تتجاوز 40 كلمة ولا تستخدم إيموجي. اكتب الرسالة فقط:';\n}\nreturn [{ json: { ...d, days_since: daysSince, _gemini_body: { contents: [{ parts: [{ text: promptText }] }], generationConfig: { temperature: 0.85, maxOutputTokens: 200, candidateCount: 1 } } } }];"
      },
      "id": "wf19-n23",
      "name": "Prep AI Prompt",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2400, 380]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://generativelanguage.googleapis.com/v1beta/models/gemini-2.0-flash:generateContent",
        "authentication": "genericCredentialType",
        "genericAuthType": "googlePalmApi",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ $json._gemini_body }}",
        "options": {}
      },
      "id": "wf19-n24",
      "name": "Gemini Generate Message",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "continueOnFail": true,
      "position": [2620, 380],
      "credentials": {
        "googlePalmApi": { "id": "s9N4V76Rwk6zW2lo", "name": "TAWD Gemini API" }
      }
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const resp = $json;\nconst ctx  = $('Prep AI Prompt').item.json;\nlet msg = '';\ntry {\n  msg = resp.candidates[0].content.parts[0].text.trim();\n} catch(e) {\n  msg = ctx.message_type === 'completed'\n    ? 'أهلاً ' + (ctx.patient_name || '') + '، مضت ' + ctx.days_since + ' يوماً من آخر زيارتك. نرحب بك دائماً — احجز موعدك الآن.'\n    : 'أهلاً ' + (ctx.patient_name || '') + '، نأسف لتعذّر حضورك في موعدك السابق. يسعدنا مساعدتك في إعادة الحجز.';\n}\nreturn [{ json: { ...ctx, message_text: msg, _ai_generated: true } }];"
      },
