      "id": "wf05-n01",
      "name": "WhatsApp Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [200, 300],
      "webhookId": "9c6d1606-c6fc-499b-b743-ec2c4e65e485"
    },
    {
      "parameters": {
        "respondWith": "noData",
        "options": { "responseCode": 200 }
      },
      "id": "wf05-n02",
      "name": "Respond 200",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [440, 300]
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const raw  = $input.first().json;\nconst body = raw.body || raw;\n\nconst entry  = (body.entry || [])[0];\nconst change = (entry?.changes || [])[0];\nconst value  = change?.value;\nconst msgs   = value?.messages || [];\n\nif (!msgs.length) {\n  return [{ json: { type: 'status_update' } }];\n}\n\nconst msg = msgs[0];\nif (msg.type !== 'text') {\n  return [{ json: { type: 'unsupported_media', from: '+' + msg.from, media_type: msg.type } }];\n}\n\nconst phoneNumberId = value?.metadata?.phone_number_id || '';\n\nreturn [{ json: {\n  type:            'message',\n  phone:           '+' + msg.from,\n  raw_from:        msg.from,\n  message_id:      msg.id,\n  message_text:    msg.text.body,\n  sender_name:     (value?.contacts || [])[0]?.profile?.name || '',\n  timestamp:       msg.timestamp,\n  phone_number_id: phoneNumberId,\n  channel:         'whatsapp',\n  waba_id:         entry?.id || ''\n}}];"
      },
      "id": "wf05-n03",
      "name": "Parse Request",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [680, 300]
    },
    {
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "loose" },
          "conditions": [
            {
              "id": "check-message-type",
              "leftValue": "={{ $json.type }}",
              "rightValue": "message",
              "operator": { "type": "string", "operation": "equals" }
            }
          ],
          "combinator": "and"
        }
      },
      "id": "wf05-n04",
      "name": "Valid Message?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [920, 300]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT clinic_id::text FROM public.channel_configs WHERE channel = 'whatsapp' AND is_active = true AND config->>'phone_number_id' = '{{ $json.phone_number_id }}' LIMIT 1;"
      },
      "id": "wf05-n38",
      "name": "Lookup Clinic Channel",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2,
      "position": [1160, 300],
      "alwaysOutputData": true,
      "credentials": {
        "postgres": { "id": "NDrVeK2iQy3c33J3", "name": "TAWD Supabase Postgres" }
      }
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const rows = $input.all();\nconst ctx  = $('Parse Request').first().json;\nif (rows.length === 0 || !rows[0].json || !rows[0].json.clinic_id) {\n  return [];\n}\nreturn [{ json: { ...ctx, clinic_id: rows[0].json.clinic_id } }];"
      },
      "id": "wf05-n39",
      "name": "Resolve Clinic ID",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
