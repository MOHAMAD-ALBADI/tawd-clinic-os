      "typeVersion": 1,
      "position": [1600, 300]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT public.clinic_has_feature('{{ $json.clinic_id }}'::uuid, 'sura_ai_enabled') AS enabled;"
      },
      "id": "wf05-n40",
      "name": "Check sura_ai_enabled",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2,
      "position": [1840, 300],
      "alwaysOutputData": true,
      "continueOnFail": true,
      "credentials": {
        "postgres": { "id": "NDrVeK2iQy3c33J3", "name": "TAWD Supabase Postgres" }
      }
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const rows = $input.all();\nconst ctx  = $('S4 Clinic Context').first().json;\n// Fail-open: DB error → allow (don't block prod on transient DB hiccup)\nconst firstRow = rows.length > 0 ? rows[0].json : {};\nconst enabled  = firstRow.error ? true : (firstRow.enabled === true);\nreturn [{ json: { ...ctx, sura_ai_enabled: enabled } }];"
      },
      "id": "wf05-n41",
      "name": "Resolve Feature Flag",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2060, 300]
