      "parameters": {
        "conditions": {
          "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "loose" },
          "conditions": [
            {
              "id": "hitl-confidence",
              "leftValue": "={{ $json.confidence }}",
              "rightValue": 0.85,
              "operator": { "type": "number", "operation": "gte" }
            },
            {
              "id": "hitl-not-sensitive",
              "leftValue": "={{ $json.is_sensitive }}",
              "rightValue": false,
              "operator": { "type": "boolean", "operation": "equals" }
            },
            {
              "id": "hitl-not-required",
              "leftValue": "={{ $json.requires_hitl }}",
              "rightValue": false,
              "operator": { "type": "boolean", "operation": "equals" }
            }
          ],
          "combinator": "and"
        }
      },
