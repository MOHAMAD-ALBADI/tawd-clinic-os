      "name": "Chat Memory",
      "type": "@n8n/n8n-nodes-langchain.memoryPostgresChat",
      "typeVersion": 1,
      "position": [4200, 680],
      "credentials": {
        "postgres": { "id": "NDrVeK2iQy3c33J3", "name": "TAWD Supabase Postgres" }
      }
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const rawOutput = $json.output || $json.text || '';\nconst ctx = $('Build AI Context').first().json;\n\nlet parsed;\ntry {\n  const cleaned = rawOutput.replace(/```json\\n?/gi,'').replace(/```\\n?/g,'').trim();\n  parsed = JSON.parse(cleaned);\n} catch(e) {\n  parsed = {\n    intent:        'unclear',\n    response_ar:   'عذراً، لم أفهم طلبك. هل يمكنك إعادة الصياغة؟',\n    confidence:    0.0,\n    is_sensitive:  false,\n    requires_hitl: false\n  };\n}\n\nreturn [{ json: {\n  ...ctx,\n  intent:        parsed.intent       || 'unclear',\n  response_ar:   parsed.response_ar  || '',\n  confidence:    parsed.confidence   ?? 0.0,\n  is_sensitive:  parsed.is_sensitive ?? false,\n  requires_hitl: parsed.requires_hitl ?? false,\n  raw_ai_output: rawOutput\n}}];"
      },
      "id": "wf05-n15",
      "name": "Parse AI Output",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [4200, 480]
    },
