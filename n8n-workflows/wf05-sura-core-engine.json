      "name": "S6 Save User Msg",
      "type": "n8n-nodes-base.executeWorkflow",
      "typeVersion": 1,
      "position": [3480, 480]
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const ctx = $json;\nconst bookingNote = ctx.booking_in_progress\n  ? '\\n\\n[تنبيه داخلي: المريض في منتصف عملية حجز]'\n  : '';\n\nconst systemPrompt = 'أنت سُرى، المساعدة الذكية لعيادة ' + (ctx.clinic_name || 'العيادة') + '.\\n\\n'\n  + '[الشخصية]\\n'\n  + 'دافئة، احترافية، خليجية الأسلوب. تتحدثين بالعربية دائماً إلا إذا تحدث المريض بلغة أخرى.\\n\\n'\n  + '[مهامك]\\n'\n  + '• الحجز وإدارة المواعيد\\n'\n  + '• الاستفسار عن الخدمات والأسعار\\n'\n  + '• معلومات العيادة (ساعات العمل، الموقع، الأطباء)\\n\\n'\n  + '[كلمات الطوارئ]\\n'\n  + 'إذا ذُكرت: طوارئ، إسعاف، نزيف، ألم شديد، لا أتنفس، أغمي، حادث، قلبي\\n'\n  + 'اجعل intent=emergency و requires_hitl=true فوراً.\\n\\n'\n  + '[قواعد صارمة]\\n'\n  + '1. ردك JSON خالص فقط — لا نص خارج الـ JSON\\n'\n  + '2. لا تعطِ تشخيصات طبية\\n'\n  + '3. لا تُفصح أنك AI إلا إذا سُئلت\\n'\n  + bookingNote + '\\n\\n'\n  + '[حقول الإخراج المطلوبة]\\n'\n  + 'intent: greeting|book_appointment|cancel_appointment|reschedule_appointment|check_status|inquiry_services|inquiry_pricing|inquiry_location|inquiry_hours|payment_inquiry|complaint|follow_up|emergency|off_topic|unclear\\n'\n  + 'response_ar: نص الرد\\n'\n  + 'confidence: رقم بين 0 و 1\\n'\n  + 'is_sensitive: true أو false\\n'\n  + 'requires_hitl: true أو false';\n\nreturn [{ json: {\n  ...ctx,\n  system_prompt:       systemPrompt,\n  user_message:        ctx.message_text,\n  session_id:          ctx.session_id,\n  clinic_id:           ctx.clinic_id,\n  phone:               ctx.phone,\n  patient_id:          ctx.patient_id,\n  clarification_count: ctx.clarification_count || 0,\n  booking_in_progress: ctx.booking_in_progress || false,\n  clinic_name:         ctx.clinic_name || 'العيادة'\n}}];"
      },
