    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const bookingResult = $json;\nconst parentCtx = $('Prep Booking Params').first().json._parent_ctx || {};\n\nconst message = bookingResult.booking_status === 'confirmed'\n  ? bookingResult.booking_confirmation_ar\n  : (bookingResult.booking_error || 'عذراً، لم أتمكن من إتمام الحجز. يرجى المحاولة لاحقاً أو التواصل معنا مباشرة.');\n\nreturn [{ json: {\n  ...parentCtx,\n  sender:         'sura',\n  message_text:   message,\n  booking_status: bookingResult.booking_status,\n  appointment_id: bookingResult.appointment_id || null\n} }];"
